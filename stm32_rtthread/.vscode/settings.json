        "PKGS_ROOT": "d:/RT-ThreadStudio/platform/env_released/env/packages",
        "PATH": "${env:PATH}"
    },
    "files.associations": {
        "*.c": "c",
        "*.h": "c",
        ".cproject": "xml",
        ".project": "xml",
        "makefile.init": "makefile",
        "makefile.defs": "makefile",
        "makefile.targets": "makefile"
    },
    "jswyll-vscode-rtthread.generate.projectType": "RT-Thread Studio",
    "jswyll-vscode-rtthread.generate.buildConfigName": "Debug",
    "jswyll-vscode-rtthread.generate.makeToolPath": "d:/RT-ThreadStudio/platform/env_released/env/tools/BuildTools/2.12-20190422-1053/bin",
    "jswyll-vscode-rtthread.generate.envPath": "d:/RT-ThreadStudio/platform/env_released/env",
    "jswyll-vscode-rtthread.generate.toolchainPath": "d:/RT-ThreadStudio/platform/env_released/env/tools/gnu_gcc/arm_gcc/mingw/bin",
    "jswyll-vscode-rtthread.generate.studioInstallPath": "d:/RT-ThreadStudio",
    "jswyll-vscode-rtthread.generate.compilerPath": "d:/RT-ThreadStudio/platform/env_released/env/tools/gnu_gcc/arm_gcc/mingw/bin/arm-none-eabi-gcc",
    "jswyll-vscode-rtthread.generate.chipName": "STM32F103C8",
    "jswyll-vscode-rtthread.generate.debuggerServerPath": "d:/RT-ThreadStudio/repo/Extract/Debugger_Support_Packages/STMicroelectronics/ST-LINK_Debugger/1.6.0/ST-LINK_gdbserver",
    "cortex-debug.variableUseNaturalFormat": true,
    "C_Cpp.autocomplete": "default",
    "C_Cpp.default.configurationProvider": "ms-vscode.cpptools",
    "C_Cpp.intelliSenseEngine": "default",
    "C_Cpp.default.compilerPath": "d:/RT-ThreadStudio/platform/env_released/env/tools/gnu_gcc/arm_gcc/mingw/bin/arm-none-eabi-gcc",


    "C_Cpp.default.compileCommands": "${workspaceFolder}/compile_commands.json",
    "C_Cpp.default.intelliSenseMode": "gcc-arm",
    "C_Cpp.errorSquiggles": "enabled",
    "C_Cpp.formatting": "default",
    "actionButtons": {
        "reloadButton": "↻",
        "commands": [
            {
                "name": "$(terminal) 串口监视",
                "color": "#ffaa00",
                "command": "$env:PYTHONHOME=$null; $env:PYTHONPATH=$null; & 'D:/STM32_project/stm32_rtthread/.venv/Scripts/python.exe' tools/serial_monitor.py"
            },
            {
                "name": "$(graph) 频谱分析",
                "color": "#00ff88",
                "command": "$env:PYTHONHOME=$null; $env:PYTHONPATH=$null; & 'D:/STM32_project/stm32_rtthread/.venv/Scripts/python.exe' tools/data_analyze.py"
            },
            {
                "name": "$(graph) 速度曲线分析",
                "color": "#00ff88",
                "command": "$env:PYTHONHOME=$null; $env:PYTHONPATH=$null; & 'D:/STM32_project/stm32_rtthread/.venv/Scripts/python.exe' tools/plotter.py"
            },
            {
                "name": "$(gear) 配置界面",
                    "color": "#ffaa00",
                    "command": "$env:PYTHONHOME=$null; $env:PYTHONPATH=$null; & 'D:/STM32_project/stm32_rtthread/.venv/Scripts/scons' --pyconfig"
                }
        ]
    },
    "python.analysis.extraPaths": [
        "${workspaceFolder}/rt-thread/tools/"
    ],
